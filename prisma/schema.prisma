generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ConfirmationStatus {
  pending
  confirmed
}

enum ProcessingStatus {
  new
  processed
  duplicate_ignored
  failed
}

enum TransactionSource {
  webhook
  poll
}

model MonitoringWallet {
  id                  String        @id @default(uuid()) @db.Uuid
  address             String        @unique @db.VarChar(34)
  label               String?       @db.VarChar(100)
  active              Boolean       @default(true)
  lastSyncedBlock     BigInt?       @map("last_synced_block")
  lastSyncedTimestamp DateTime?     @map("last_synced_timestamp") @db.Timestamptz(6)
  createdAt           DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  transactions        Transaction[]

  @@map("monitoring_wallets")
}

model Transaction {
  id                 String             @id @default(uuid()) @db.Uuid
  walletId           String             @map("wallet_id") @db.Uuid
  transactionHash    String             @unique @map("transaction_hash") @db.Char(64)
  senderAddress      String             @map("sender_address") @db.VarChar(34)
  recipientAddress   String             @map("recipient_address") @db.VarChar(34)
  amount             Decimal            @db.Decimal(38, 6)
  amountRaw          String             @map("amount_raw") @db.VarChar(78)
  tokenSymbol        String             @map("token_symbol") @db.VarChar(20)
  contractAddress    String             @map("contract_address") @db.VarChar(34)
  blockNumber        BigInt             @map("block_number")
  blockTimestamp     DateTime           @map("block_timestamp") @db.Timestamptz(6)
  confirmations      Int                @default(0)
  confirmationStatus ConfirmationStatus @default(pending) @map("confirmation_status")
  processingStatus   ProcessingStatus   @default(new) @map("processing_status")
  source             TransactionSource
  createdAt          DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)

  wallet MonitoringWallet @relation(fields: [walletId], references: [id], onDelete: Restrict)

  @@index([confirmationStatus], map: "transactions_confirmation_status_idx")
  @@index([blockNumber], map: "transactions_block_number_idx")
  @@index([recipientAddress], map: "transactions_recipient_address_idx")
  @@map("transactions")
}

model WebhookEventsLog {
  id           String   @id @default(uuid()) @db.Uuid
  rawPayload   Json     @map("raw_payload")
  receivedAt   DateTime @default(now()) @map("received_at") @db.Timestamptz(6)
  processed    Boolean  @default(false)
  errorMessage String?  @map("error_message")

  @@map("webhook_events_log")
}
