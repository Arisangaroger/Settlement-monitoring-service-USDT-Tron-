# Network: nile | mainnet | shasta
TRON_NETWORK=nile

# TronGrid base URL (defaults per network if omitted)
# TRONGRID_BASE_URL=https://nile.trongrid.io

# Optional on Nile; recommended on mainnet to avoid rate limits
# TRONGRID_API_KEY=your-trongrid-api-key

# Wallet to monitor for incoming USDT (your Nile test wallet)
MONITORED_WALLET_ADDRESS=

# USDT TRC20 contract (defaults per network if omitted)
# Nile:  TXYZopYRdj2D9XRtbG411XZZ3kM5VkAeBf
# Mainnet: TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t
# USDT_CONTRACT_ADDRESS=

# Confirmations required before marking a tx as "confirmed"
CONFIRMATION_THRESHOLD=19

# QuickNode (Phase 5 prep — not required for Phase 1 scripts)
# QUICKNODE_TRON_HTTP_URL=
