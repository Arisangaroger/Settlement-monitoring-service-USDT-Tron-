{
  "openapi": "3.0.0",
  "paths": {
    "/api/wallets/monitored": {
      "get": {
        "description": "Returns the active wallet from the database. No redeploy needed when this changes via PUT.",
        "operationId": "WalletsController_getMonitored",
        "parameters": [],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MonitoredWalletSuccessResponseDto"
                }
              }
            }
          },
          "400": {
            "description": "Validation failed or malformed request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorResponseDto"
                }
              }
            }
          },
          "404": {
            "description": "No monitored wallet configured (connect TronLink or set MONITORED_WALLET_ADDRESS)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorResponseDto"
                }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded (global throttler)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorResponseDto"
                }
              }
            }
          },
          "500": {
            "description": "Unexpected server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorResponseDto"
                }
              }
            }
          }
        },
        "summary": "Get the currently monitored wallet",
        "tags": [
          "wallets"
        ]
      },
      "put": {
        "description": "Updates the active monitored wallet at runtime. Resets sync watermarks for the new address.",
        "operationId": "WalletsController_setMonitored",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SetMonitoredWalletDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MonitoredWalletSuccessResponseDto"
                }
              }
            }
          },
          "400": {
            "description": "Validation failed or malformed request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorResponseDto"
                }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded (global throttler)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorResponseDto"
                }
              }
            }
          },
          "500": {
            "description": "Unexpected server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorResponseDto"
                }
              }
            }
          }
        },
        "summary": "Set the wallet to monitor (public — connect via TronLink in dashboard)",
        "tags": [
          "wallets"
        ]
      }
    },
    "/api/transactions": {
      "get": {
        "description": "Returns transactions for the active monitored wallet only. Use filters and sorting for dashboard views.",
        "operationId": "TransactionsController_list",
        "parameters": [
          {
            "name": "page",
            "required": false,
            "in": "query",
            "schema": {
              "$ref": "#/components/schemas/Object"
            }
          },
          {
            "name": "limit",
            "required": false,
            "in": "query",
            "schema": {
              "$ref": "#/components/schemas/Object"
            }
          },
          {
            "name": "confirmationStatus",
            "required": false,
            "in": "query",
            "schema": {
              "enum": [
                "pending",
                "confirmed"
              ],
              "type": "string"
            }
          },
          {
            "name": "processingStatus",
            "required": false,
            "in": "query",
            "schema": {
              "enum": [
                "new",
                "processed",
                "duplicate_ignored",
                "failed"
              ],
              "type": "string"
            }
          },
          {
            "name": "sortBy",
            "required": false,
            "in": "query",
            "schema": {
              "default": "block_timestamp",
              "enum": [
                "block_timestamp",
                "amount",
                "created_at"
              ],
              "type": "string"
            }
          },
          {
            "name": "order",
            "required": false,
            "in": "query",
            "schema": {
              "default": "desc",
              "enum": [
                "asc",
                "desc"
              ],
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedTransactionsResponseDto"
                }
              }
            }
          },
          "400": {
            "description": "Validation failed or malformed request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorResponseDto"
                }
              }
            }
          },
          "404": {
            "description": "No monitored wallet configured (connect TronLink or set MONITORED_WALLET_ADDRESS)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorResponseDto"
                }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded (global throttler)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorResponseDto"
                }
              }
            }
          },
          "500": {
            "description": "Unexpected server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorResponseDto"
                }
              }
            }
          }
        },
        "summary": "List transactions (paginated, filterable)",
        "tags": [
          "transactions"
        ]
      }
    },
    "/api/transactions/search": {
      "get": {
        "description": "Looks up a transaction by on-chain hash within the active monitored wallet.",
        "operationId": "TransactionsController_searchByHash",
        "parameters": [
          {
            "name": "hash",
            "required": true,
            "in": "query",
            "description": "64-character TRON transaction hash (hex)",
            "schema": {
              "example": "f096b4ca3f10109130ee5f5ad1f45b315f97f41c4a3a7ad5e9d02989111894e1",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TransactionSuccessResponseDto"
                }
              }
            }
          },
          "400": {
            "description": "Validation failed or malformed request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorResponseDto"
                }
              }
            }
          },
          "404": {
            "description": "No monitored wallet configured, or resource not found for the active wallet",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorResponseDto"
                }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded (global throttler)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorResponseDto"
                }
              }
            }
          },
          "500": {
            "description": "Unexpected server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorResponseDto"
                }
              }
            }
          }
        },
        "summary": "Search transaction by hash",
        "tags": [
          "transactions"
        ]
      }
    },
    "/api/transactions/{id}": {
      "get": {
        "description": "Returns a single transaction by database id for the active monitored wallet.",
        "operationId": "TransactionsController_getById",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
