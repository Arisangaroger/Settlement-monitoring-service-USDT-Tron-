# =============================================================================
# Stablecoin Settlement Monitor — Environment Configuration
# Copy this file to `.env` and fill in required values.
#
# Minimum for `docker compose up --build`:
#   TRONGRID_API_KEY
#
# Wallet to monitor: set via TronLink in the dashboard (Connect wallet).
# MONITORED_WALLET_ADDRESS below is optional — only for seeding without TronLink
# or for `npm run docker:demo` auto Tatum registration at startup.
# =============================================================================

# --- Docker Compose ports (change if these conflict with other local apps) ---
POSTGRES_HOST_PORT=5433
BACKEND_PORT=3000
FRONTEND_PORT=3001

# --- Database credentials (optional — defaults match docker-compose.yml) ---
# POSTGRES_USER=settlement
# POSTGRES_PASSWORD=settlement
# POSTGRES_DB=settlement_monitor

# --- Database (required) ---
# Local dev / host tools (psql, Prisma Studio):
DATABASE_URL="postgresql://settlement:settlement@localhost:5433/settlement_monitor?schema=public"
# Docker Compose overrides DATABASE_URL internally to use hostname `postgres`.

# --- Backend (required) ---
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# --- TRON / TronGrid (required) ---
TRON_NETWORK=shasta
TRONGRID_BASE_URL=https://api.shasta.trongrid.io
TRONGRID_API_KEY=your-trongrid-api-key

# Monitored wallet — optional (normally set via TronLink Connect wallet in the dashboard)
# Use only if you want a default wallet without TronLink, or for docker:demo Tatum auto-register
# MONITORED_WALLET_ADDRESS=

# USDT TRC20 contract (optional — auto-selected per TRON_NETWORK if omitted)
# Shasta: TG3XXyExBkPp9nzdajDZsozEu4BkaSJozs
# USDT_CONTRACT_ADDRESS=

# --- Background jobs (optional — defaults shown) ---
RECONCILIATION_INTERVAL_MS=240000
CONFIRMATION_CHECK_INTERVAL_MS=12000
CONFIRMATION_THRESHOLD=19

# --- API security (optional — defaults shown) ---
CORS_ORIGIN=http://localhost:3001
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100

# --- Tatum webhooks ---
# Required for `npm run docker:demo` (free Tatum account).
# For auto-registration at startup, also set MONITORED_WALLET_ADDRESS to the same wallet you use in TronLink.
TATUM_API_KEY=your-tatum-api-key

# Optional production webhook security. If unset, HMAC validation is disabled (local dev only).
# TATUM_WEBHOOK_HMAC_SECRET=your-tatum-hmac-secret

# --- Stable public URL for webhooks (optional — not needed for `npm run docker:demo`) ---
# See docs/webhook-tunnel-setup.md for ngrok / Cloudflare Named Tunnel profiles.

# Option A: ngrok static domain (`docker compose --profile webhook-tunnel up`)
# NGROK_AUTHTOKEN=your-ngrok-authtoken
# NGROK_DOMAIN=your-name.ngrok-free.app

# Option B: Cloudflare Named Tunnel (`docker compose --profile webhook-tunnel-cf up`)
# CLOUDFLARE_TUNNEL_TOKEN=your-cloudflare-tunnel-token
# WEBHOOK_PUBLIC_URL=https://settlement-api.yourdomain.com

# Used by `npm run webhook:register` when registering manually
# WEBHOOK_PUBLIC_URL=https://your-name.ngrok-free.app

# --- Frontend (local dev only; Docker bakes API URL at build time) ---
NEXT_PUBLIC_API_URL=http://localhost:3000/api
