# =============================================================================
# Stablecoin Settlement Monitor — Environment Configuration
# Copy this file to `.env` and fill in required values.
# =============================================================================

# --- Docker Compose ports (optional overrides) ---
POSTGRES_HOST_PORT=5433
BACKEND_PORT=3000
FRONTEND_PORT=3001

# --- Database ---
# Local dev (Postgres on host port 5433):
DATABASE_URL="postgresql://settlement:settlement@localhost:5433/settlement_monitor?schema=public"
# Docker Compose overrides DATABASE_URL internally to use hostname `postgres`.

# --- Backend ---
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# --- TRON / TronGrid (required) ---
TRON_NETWORK=shasta
TRONGRID_BASE_URL=https://api.shasta.trongrid.io
TRONGRID_API_KEY=your-trongrid-api-key

# Monitored wallet — Shasta testnet address (required)
MONITORED_WALLET_ADDRESS=

# USDT TRC20 contract (auto-selected per TRON_NETWORK if omitted)
# Shasta: TG3XXyExBkPp9nzdajDZsozEu4BkaSJozs
# USDT_CONTRACT_ADDRESS=

# --- Background jobs (milliseconds) ---
RECONCILIATION_INTERVAL_MS=300000
CONFIRMATION_CHECK_INTERVAL_MS=12000
CONFIRMATION_THRESHOLD=19

# --- API security ---
CORS_ORIGIN=http://localhost:3001
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100

# --- Tatum webhooks (optional — fast path) ---
# Required for production webhook security. If unset, HMAC validation is disabled (local dev only).
# TATUM_WEBHOOK_HMAC_SECRET=your-tatum-hmac-secret

# --- Frontend (local dev only; Docker bakes this at build time) ---
NEXT_PUBLIC_API_URL=http://localhost:3000/api
